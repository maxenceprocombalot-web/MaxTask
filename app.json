{
  "expo": {
    "name": "MaxTask",
    "slug": "maxtask",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#080a0e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.maxence.maxtask",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080a0e",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.maxence.maxtask"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#7c6dfa"
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "726749a8-dbce-4ccc-9849-d7c9837ef4df"
      }
    }
  }
}
